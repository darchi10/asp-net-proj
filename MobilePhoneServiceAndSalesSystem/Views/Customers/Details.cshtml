@model MobilePhoneServiceAndSalesSystem.Models.Customer

@{
    ViewData["Title"] = "Customer Profile";
}

<div class="container mt-4 mb-5">
    <div class="row g-4">
        <!-- Profile Dashboard -->
        <div class="col-lg-4">
            <div class="card h-100 shadow-sm border-0 bg-dark text-light rounded-4">
                <div class="card-body text-center p-5">
                    <div class="avatar-circle bg-primary text-white mb-4 mx-auto d-flex align-items-center justify-content-center" style="width: 80px; height: 80px; border-radius: 50%; font-size: 2rem;">
                        @(Model.FirstName.FirstOrDefault())@(Model.LastName.FirstOrDefault())
                    </div>
                    <h3 class="mb-1 fw-bold">@Model.FirstName @Model.LastName</h3>
                    <p class="text-secondary mb-4">Customer #@Model.Id</p>
                    
                    <div class="d-flex flex-column gap-3 text-start mt-4">
                        <div class="d-flex align-items-center">
                            <i class="bi bi-envelope-fill text-primary me-3 fs-5"></i>
                            <div>
                                <small class="text-secondary d-block">Email</small>
                                <span>@Model.Email</span>
                            </div>
                        </div>
                        <div class="d-flex align-items-center">
                            <i class="bi bi-telephone-fill text-primary me-3 fs-5"></i>
                            <div>
                                <small class="text-secondary d-block">Phone</small>
                                <span>@Model.PhoneNumber</span>
                            </div>
                        </div>
                         <div class="d-flex align-items-center">
                            <i class="bi bi-geo-alt-fill text-primary me-3 fs-5"></i>
                            <div>
                                <small class="text-secondary d-block">Address</small>
                                <span>@Model.Address</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Stats & Activity -->
        <div class="col-lg-8">
            <div class="row g-4 mb-4">
                <div class="col-md-6">
                    <div class="card shadow-sm border-0 bg-dark text-light rounded-4 h-100">
                        <div class="card-body p-4 d-flex align-items-center justify-content-between">
                            <div>
                                <h6 class="text-secondary mb-1">Registered Phones</h6>
                                <h2 class="mb-0 fw-bold">@Model.Phones.Count</h2>
                            </div>
                            <div class="bg-primary bg-opacity-10 text-primary rounded-circle p-3">
                                <i class="bi bi-phone fs-3"></i>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card shadow-sm border-0 bg-dark text-light rounded-4 h-100">
                        <div class="card-body p-4 d-flex align-items-center justify-content-between">
                            <div>
                                <h6 class="text-secondary mb-1">Total Orders</h6>
                                <h2 class="mb-0 fw-bold">@Model.Orders.Count</h2>
                            </div>
                            <div class="bg-success bg-opacity-10 text-success rounded-circle p-3">
                                <i class="bi bi-bag-check fs-3"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm border-0 bg-dark text-light rounded-4 mb-4">
                <div class="card-header border-bottom border-secondary bg-transparent p-4">
                    <h5 class="mb-0 fw-bold"><i class="bi bi-phone me-2 text-primary"></i>Device Portfolio</h5>
                </div>
                <div class="card-body p-0">
                    @if (Model.Phones.Count > 0)
                    {
                        <div class="list-group list-group-flush rounded-bottom-4">
                        @foreach (var phone in Model.Phones)
                        {
                            <div class="list-group-item bg-dark text-light border-secondary p-4 d-flex justify-content-between align-items-center">
                                <div>
                                    <h6 class="mb-1 fw-bold">@phone.Brand @phone.Model</h6>
                                    <small class="text-secondary">IMEI: @phone.IMEI</small>
                                </div>
                                <span class="badge bg-secondary rounded-pill">#@phone.Id</span>
                            </div>
                        }
                        </div>
                    }
                    else
                    {
                        <div class="p-4 text-center text-secondary">
                            <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                            <p class="mb-0">No registered devices</p>
                        </div>
                    }
                </div>
            </div>

            <div class="card shadow-sm border-0 bg-dark text-light rounded-4">
                <div class="card-header border-bottom border-secondary bg-transparent p-4">
                    <h5 class="mb-0 fw-bold"><i class="bi bi-receipt me-2 text-primary"></i>Order History</h5>
                </div>
                <div class="card-body p-0">
                     @if (Model.Orders.Count > 0)
                    {
                        <div class="list-group list-group-flush rounded-bottom-4">
                        @foreach (var order in Model.Orders)
                        {
                            <div class="list-group-item bg-dark text-light border-secondary p-4 d-flex justify-content-between align-items-center">
                                <div>
                                    <div class="d-flex align-items-center gap-2 mb-1">
                                        <span class="badge bg-primary">Order #@order.Id</span>
                                        <small class="text-secondary">@order.OrderDate.ToString("MMM dd, yyyy")</small>
                                    </div>
                                    <h6 class="mb-0 fw-bold text-success">@order.TotalAmount EUR</h6>
                                </div>
                                <i class="bi bi-chevron-right text-secondary"></i>
                            </div>
                        }
                        </div>
                    }
                    else
                    {
                         <div class="p-4 text-center text-secondary">
                            <p class="mb-0">No order history available</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
    
    <div class="mt-4">
        <a asp-controller="Customers" asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">
            <i class="bi bi-arrow-left me-2"></i>Back to Directory
        </a>
    </div>
</div>
