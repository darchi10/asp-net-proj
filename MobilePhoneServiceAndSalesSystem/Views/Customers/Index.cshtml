@model IEnumerable<MobilePhoneServiceAndSalesSystem.Models.Customer>

@{
    ViewData["Title"] = "Customers";
}

@if (!Model.Any())
{
    <div class="empty-state text-center py-5 rounded-4 shadow-sm border border-secondary bg-dark text-muted">
        <div class="display-4 mb-3">
            <i class="bi bi-people text-secondary"></i>
        </div>
        <h3 class="fw-light">No customers found</h3>
        <p class="mb-4">You haven't added any customers directly or via orders yet.</p>
        <a asp-action="Create" class="btn btn-outline-primary rounded-pill px-4">Register a customer</a>
    </div>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom border-secondary">
        <div>
            <h2 class="h3 mb-0 text-white"><i class="bi bi-people me-2 text-primary"></i>Customers Overview</h2>
            <p class="text-muted small mb-0 mt-1">Manage and track your customer base</p>
        </div>
        <a asp-action="Create" class="btn btn-primary rounded-pill px-4 shadow-sm">
            <i class="bi bi-person-plus me-2"></i>New Customer
        </a>
    </div>

    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        @foreach (var customer in Model)
        {
            <div class="col">
                <div class="card bg-dark text-light border-secondary h-100 shadow-sm custom-card-hover" onclick="window.location='@Url.Action("Details", "Customers", new { id = customer.Id })'" style="cursor: pointer; transition: transform 0.2s, box-shadow 0.2s;">
                    <div class="card-body d-flex flex-column">
                        <div class="d-flex align-items-center mb-3">
                            <i class="bi bi-person-circle display-6 text-primary me-3"></i>
                            <div>
                                <h5 class="card-title fw-bold text-white mb-0">
                                    @customer.FirstName @customer.LastName
                                </h5>
                                <span class="badge bg-dark border border-secondary text-secondary mt-1">Customer ID: #@customer.Id</span>
                            </div>
                        </div>

                        <div class="card-text text-muted mb-4 small d-flex flex-column gap-2 flex-grow-1">
                            <span class="d-flex align-items-center">
                                <i class="bi bi-envelope me-2 text-secondary"></i> <strong>Email:</strong>&nbsp;@customer.Email
                            </span>
                            <span class="d-flex align-items-center">
                                <i class="bi bi-telephone me-2 text-secondary"></i> <strong>Phone:</strong>&nbsp;@customer.PhoneNumber
                            </span>
                            <span class="d-flex align-items-start">
                                <i class="bi bi-geo-alt me-2 text-secondary mt-1"></i> 
                                <span><strong>Address:</strong><br/>@customer.Address</span>
                            </span>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mt-auto border-top border-secondary pt-3">
                            <span class="badge bg-secondary bg-opacity-25 text-light border border-secondary px-3 py-2 rounded-pill">
                                <i class="bi bi-phone me-1"></i> @customer.Phones.Count Devices
                            </span>
                            <span class="badge bg-primary bg-opacity-25 text-primary border border-primary px-3 py-2 rounded-pill">
                                <i class="bi bi-bag-check me-1"></i> @customer.Orders.Count Orders
                            </span>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

<style>
    .custom-card-hover:hover {
        transform: translateY(-5px);
        box-shadow: 0 .5rem 1rem rgba(0,0,0,.3)!important;
        border-color: var(--bs-primary) !important;
    }
    .empty-state {
        background: linear-gradient(145deg, #1e1e24, #121215);
    }
</style>
