@{
    ViewData["Title"] = "Dashboard";
}

<div class="container py-5">
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold mb-3">Welcome to <span class="text-primary">Mobi</span>Service</h1>
        <p class="lead text-secondary w-75 mx-auto">
            Manage your service center efficiently. Track repairs, serve customers, and process sales in one comprehensive platform.
        </p>
    </div>

    <div class="row g-4 mt-2">
        <!-- Service & Repairs -->
        <div class="col-md-6 col-lg-4">
            <a asp-controller="RepairJobs" asp-action="Index" class="text-decoration-none">
                <div class="retail-card p-4">
                    <div class="retail-card-icon">🔧</div>
                    <h3 class="retail-card-title">Repair Jobs</h3>
                    <p class="retail-card-text">Track current and past service tickets, update their statuses, and manage workflow.</p>
                </div>
            </a>
        </div>

        <!-- Sales & Store -->
        <div class="col-md-6 col-lg-4">
            <a asp-controller="Products" asp-action="Index" class="text-decoration-none">
                <div class="retail-card p-4">
                    <div class="retail-card-icon">📱</div>
                    <h3 class="retail-card-title">Products Store</h3>
                    <p class="retail-card-text">Explore inventory, feature new phones and accessories, and process sales.</p>
                </div>
            </a>
        </div>

        <!-- Orders -->
        <div class="col-md-6 col-lg-4">
            <a asp-controller="Orders" asp-action="Index" class="text-decoration-none">
                <div class="retail-card p-4">
                    <div class="retail-card-icon">📦</div>
                    <h3 class="retail-card-title">Manage Orders</h3>
                    <p class="retail-card-text">Keep track of customer purchases and review order histories effortlessly.</p>
                </div>
            </a>
        </div>

        <!-- Customers -->
        <div class="col-md-6 col-lg-4">
            <a asp-controller="Customers" asp-action="Index" class="text-decoration-none">
                <div class="retail-card p-4">
                    <div class="retail-card-icon">👥</div>
                    <h3 class="retail-card-title">Customers</h3>
                    <p class="retail-card-text">Manage your client database, communications, and customer histories.</p>
                </div>
            </a>
        </div>
        
        <!-- Inventory / Spare Parts -->
        <div class="col-md-6 col-lg-4">
            <a asp-controller="SpareParts" asp-action="Index" class="text-decoration-none">
                <div class="retail-card p-4">
                    <div class="retail-card-icon">⚙️</div>
                    <h3 class="retail-card-title">Spare Parts</h3>
                    <p class="retail-card-text">Keep your service inventory stocked. Manage parts and usage for tech repairs.</p>
                </div>
            </a>
        </div>

        <!-- Technicians -->
        <div class="col-md-6 col-lg-4">
            <a asp-controller="Technicians" asp-action="Index" class="text-decoration-none">
                <div class="retail-card p-4">
                    <div class="retail-card-icon">🧑‍🔧</div>
                    <h3 class="retail-card-title">Technicians</h3>
                    <p class="retail-card-text">View your team, assign jobs, and overview personnel performance.</p>
                </div>
            </a>
        </div>
    </div>
</div>


