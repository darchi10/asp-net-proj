@model IEnumerable<MobilePhoneServiceAndSalesSystem.Models.Order>

@{
    ViewData["Title"] = "Orders";
}

@if (!Model.Any())
{
    <div class="empty-state text-center py-5 rounded-4 shadow-sm border border-secondary bg-dark text-muted">
        <div class="display-4 mb-3">
            <i class="bi bi-inbox text-secondary"></i>
        </div>
        <h3 class="fw-light">No orders found</h3>
        <p class="mb-4">It looks like there are no orders in the system yet.</p>
        <a asp-action="Create" class="btn btn-outline-primary rounded-pill px-4">Create the first order</a>
    </div>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom border-secondary">
        <div>
            <h2 class="h3 mb-0 text-white"><i class="bi bi-receipt me-2 text-primary"></i>Sales Orders</h2>
            <p class="text-muted small mb-0 mt-1">Manage product orders and fulfillment</p>
        </div>
        <a asp-action="Create" class="btn btn-primary rounded-pill px-4 shadow-sm">
            <i class="bi bi-cart-plus me-2"></i>New Order
        </a>
    </div>

    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        @foreach (var order in Model)
        {
            <div class="col">
                <div class="card bg-dark text-light border-secondary h-100 shadow-sm custom-card-hover" onclick="window.location='@Url.Action("Details", "Orders", new { id = order.Id })'" style="cursor: pointer; transition: transform 0.2s, box-shadow 0.2s;">
                    <div class="card-body d-flex flex-column">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <span class="badge bg-primary bg-opacity-25 text-primary border border-primary px-3 py-2 rounded-pill">Order #@order.Id</span>
                            <span class="badge bg-dark border border-secondary text-secondary px-3 py-2 rounded-pill"><i class="bi bi-calendar-event me-2"></i>@order.OrderDate.ToShortDateString()</span>
                        </div>
                        
                        <h5 class="card-title fw-bold text-white mb-2 d-flex align-items-center">
                            <i class="bi bi-person-circle me-2 text-secondary"></i>
                            @(order.Customer is null ? "Unknown Customer" : $"{order.Customer.FirstName} {order.Customer.LastName}")
                        </h5>
                        <div class="card-text text-muted mb-4 small flex-grow-1">
                            <div class="d-flex align-items-start mt-2">
                                <i class="bi bi-geo-alt me-2 text-secondary mt-1"></i>
                                <span><strong>Shipping Address:</strong><br/>@order.ShippingAddress</span>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mt-auto border-top border-secondary pt-3">
                            <div class="d-flex align-items-center">
                                <span class="badge bg-secondary bg-opacity-25 text-light border border-secondary px-3 py-2 rounded-pill">
                                    <i class="bi bi-box-seam me-1"></i> @order.OrderItems.Count Items
                                </span>
                            </div>
                            <div class="text-end">
                                <span class="fw-bold fs-5 text-success">€@order.TotalAmount</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

<style>
    .custom-card-hover:hover {
        transform: translateY(-5px);
        box-shadow: 0 .5rem 1rem rgba(0,0,0,.3)!important;
        border-color: var(--bs-primary) !important;
    }
    .empty-state {
        background: linear-gradient(145deg, #1e1e24, #121215);
    }
</style>
