@model MobilePhoneServiceAndSalesSystem.Models.Product

@{
    ViewData["Title"] = "Product Showcase";
}

<div class="container mt-5 mb-5">
    <div class="row g-5 align-items-center">
        <!-- Visual Presentation area -->
        <div class="col-lg-6 text-center">
            <div class="position-relative d-inline-block">
                <div class="bg-primary rounded-circle position-absolute top-50 start-50 translate-middle opacity-25" style="width: 300px; height: 300px; filter: blur(50px);"></div>
                <div class="card bg-dark border border-secondary shadow-lg rounded-4 p-5 position-relative z-1" style="aspect-ratio: 1/1;">
                    <div class="d-flex h-100 flex-column justify-content-center align-items-center text-secondary">
                        <i class="bi bi-box-seam" style="font-size: 8rem;"></i>
                        <span class="mt-3 text-uppercase fw-bold" style="letter-spacing: 2px;">SKU-#@Model.Id</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Product Specs & Action -->
        <div class="col-lg-6">
            <div class="d-flex flex-column h-100 justify-content-center">
                <span class="badge bg-secondary mb-3 align-self-start py-2 px-3 text-uppercase" style="letter-spacing: 1px;">Store / Products</span>
                
                <h1 class="display-4 fw-bold text-light mb-3">@Model.Name</h1>
                
                <div class="d-flex align-items-baseline gap-3 mb-4">
                    <h2 class="text-success fw-bold mb-0">@Model.CurrentPrice EUR</h2>
                    @if (Model.StockQuantity > 0)
                    {
                        <span class="badge bg-success bg-opacity-10 text-success border border-success rounded-pill px-3 py-2">
                            <i class="bi bi-check-circle me-1"></i> In Stock (@Model.StockQuantity)
                        </span>
                    }
                    else
                    {
                         <span class="badge bg-danger bg-opacity-10 text-danger border border-danger rounded-pill px-3 py-2">
                            <i class="bi bi-x-circle me-1"></i> Out of Stock
                        </span>
                    }
                </div>

                <div class="bg-dark p-4 rounded-4 border border-secondary mb-4 shadow-sm text-light">
                    <h6 class="text-secondary text-uppercase fw-bold mb-2" style="font-size: 0.8rem; letter-spacing: 1px;">Description</h6>
                    <p class="mb-0 fs-5" style="line-height: 1.6;">@Model.Description</p>
                </div>

                <div class="d-flex gap-3 mt-2">
                     <a asp-controller="Products" asp-action="Index" class="btn btn-outline-light rounded-pill px-5 py-3 fw-bold flex-grow-1 text-center">
                        <i class="bi bi-arrow-left me-2"></i>Back to Browse
                    </a>
                </div>
                
                @if(Model.OrderItems.Count > 0)
                {
                    <div class="mt-5 border-top border-secondary pt-4">
                        <h6 class="text-secondary mb-3"><i class="bi bi-graph-up me-2"></i>Sales Performance</h6>
                        <p class="text-light mb-0">Featured in <strong>@Model.OrderItems.Count</strong> customer orders.</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
