@model IEnumerable<MobilePhoneServiceAndSalesSystem.Models.Product>

@{
    ViewData["Title"] = "Products";
}

@if (!Model.Any())
{
    <div class="empty-state text-center py-5 rounded-4 shadow-sm border border-secondary bg-dark text-muted">
        <div class="display-4 mb-3">
            <i class="bi bi-cart-x text-secondary"></i>
        </div>
        <h3 class="fw-light">No products available</h3>
        <p class="mb-4">You haven't added any products to your inventory yet.</p>
        <a asp-action="Create" class="btn btn-outline-primary rounded-pill px-4">Create your first product</a>
    </div>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom border-secondary">
        <div>
            <h2 class="h3 mb-0 text-white"><i class="bi bi-shop me-2 text-primary"></i>Product Inventory</h2>
            <p class="text-muted small mb-0 mt-1">Manage items available for sale</p>
        </div>
        <a asp-action="Create" class="btn btn-primary rounded-pill px-4 shadow-sm">
            <i class="bi bi-plus-lg me-2"></i>Add Product
        </a>
    </div>

    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-4 g-4">
        @foreach (var product in Model)
        {
            <div class="col">
                <div class="card bg-dark text-light border-secondary h-100 shadow-sm custom-card-hover" onclick="window.location='@Url.Action("Details", "Products", new { id = product.Id })'" style="cursor: pointer; transition: transform 0.2s, box-shadow 0.2s;">
                    <div class="card-body d-flex flex-column">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <span class="badge bg-dark border border-secondary text-secondary px-3 py-2 rounded-pill">ID #@product.Id</span>
                            @if (product.StockQuantity > 0)
                            {
                                <span class="badge bg-success bg-opacity-25 text-success rounded-pill border border-success px-3 py-2"><i class="bi bi-box-seam me-1"></i> @product.StockQuantity In Stock</span>
                            }
                            else
                            {
                                <span class="badge bg-danger bg-opacity-25 text-danger rounded-pill border border-danger px-3 py-2"><i class="bi bi-exclamation-triangle me-1"></i> Out of Stock</span>
                            }
                        </div>
                        
                        <h5 class="card-title fw-bold text-white mb-2 pb-2 border-bottom border-secondary border-opacity-50">
                            @product.Name
                        </h5>
                        <p class="card-text text-muted mb-4 small flex-grow-1" style="display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;">
                            <strong>Description:</strong><br/>
                            @product.Description
                        </p>

                        <div class="d-flex justify-content-between align-items-center mt-auto border-top border-secondary pt-3">
                            <div class="d-flex align-items-center">
                                <span class="fw-bold fs-5 text-primary">€@product.CurrentPrice</span>
                            </div>
                            <div class="text-end">
                                <span class="badge bg-secondary bg-opacity-25 text-light border border-secondary p-2 rounded-circle">
                                    <i class="bi bi-chevron-right"></i>
                                </span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

<style>
    .custom-card-hover:hover {
        transform: translateY(-5px);
        box-shadow: 0 .5rem 1rem rgba(0,0,0,.3)!important;
        border-color: var(--bs-primary) !important;
    }
    .empty-state {
        background: linear-gradient(145deg, #1e1e24, #121215);
    }
</style>
