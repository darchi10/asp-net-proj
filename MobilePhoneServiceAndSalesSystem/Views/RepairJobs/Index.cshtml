@model IEnumerable<MobilePhoneServiceAndSalesSystem.Models.RepairJob>

@{
    ViewData["Title"] = "Repair Jobs";
}

@if (!Model.Any())
{
    <div class="empty-state text-center py-5 rounded-4 shadow-sm border border-secondary bg-dark text-muted">
        <div class="display-4 mb-3">
            <i class="bi bi-wrench text-secondary"></i>
        </div>
        <h3 class="fw-light">No repair jobs</h3>
        <p class="mb-4">No devices are currently registered for service or repair.</p>
        <a asp-action="Create" class="btn btn-outline-primary rounded-pill px-4">Start a new repair</a>
    </div>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom border-secondary">
        <div>
            <h2 class="h3 mb-0 text-white"><i class="bi bi-tools me-2 text-primary"></i>Repair Jobs</h2>
            <p class="text-muted small mb-0 mt-1">Track device repair statuses and technician assignments</p>
        </div>
        <a asp-action="Create" class="btn btn-primary rounded-pill px-4 shadow-sm">
            <i class="bi bi-plus text-white me-1"></i>New Repair Job
        </a>
    </div>

    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        @foreach (var repairJob in Model)
        {
            <div class="col">
                <div class="card bg-dark text-light border-secondary h-100 shadow-sm custom-card-hover" onclick="window.location='@Url.Action("Details", "RepairJobs", new { id = repairJob.Id })'" style="cursor: pointer; transition: transform 0.2s, box-shadow 0.2s;">
                    <div class="card-body d-flex flex-column">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <span class="badge bg-primary bg-opacity-25 text-primary border border-primary px-3 py-2 rounded-pill">Job #@repairJob.Id</span>
                            <span class="badge @(repairJob.Status.ToString() == "Completed" ? "bg-success bg-opacity-25 text-success border border-success" : (repairJob.Status.ToString() == "InProgress" ? "bg-warning bg-opacity-25 text-warning border border-warning" : "bg-secondary bg-opacity-25 text-light border border-secondary")) px-3 py-2 rounded-pill">
                                <i class="bi @(repairJob.Status.ToString() == "Completed" ? "bi-check-circle" : (repairJob.Status.ToString() == "InProgress" ? "bi-arrow-repeat" : "bi-clock")) me-1"></i> @repairJob.Status
                            </span>
                        </div>
                        
                        <h5 class="card-title fw-bold text-white mb-3" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                            @repairJob.Description
                        </h5>
                        
                        <div class="card-text text-muted mb-3 small d-flex flex-column gap-2 flex-grow-1">
                            <span class="d-flex align-items-center bg-dark p-2 rounded border border-secondary border-opacity-50">
                                <i class="bi bi-calendar-arrow-down me-2 text-primary"></i> <strong>Received:</strong> <span class="ms-auto text-light">@repairJob.ReceivedDate.ToShortDateString()</span>
                            </span>
                            <span class="d-flex align-items-center bg-dark p-2 rounded border border-secondary border-opacity-50">
                                <i class="bi bi-calendar-check me-2 text-success"></i> <strong>Completed:</strong> <span class="ms-auto text-light">@(repairJob.CompletedDate.HasValue ? repairJob.CompletedDate.Value.ToShortDateString() : "Pending")</span>
                            </span>
                        </div>

                        <div class="mb-3 border-top border-secondary pt-3">
                            <span class="d-block text-muted small mb-1 fw-bold">Assigned Technician</span>
                            <div class="text-light fs-6 d-flex align-items-center">
                                <i class="bi bi-person-badge me-2 text-secondary"></i>
                                @(repairJob.Technician is null ? "Unassigned" : $"{repairJob.Technician.FirstName} {repairJob.Technician.LastName}")
                            </div>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mt-auto border-top border-secondary pt-3">
                            <span class="badge bg-dark border border-secondary text-info px-3 py-2 rounded-pill">
                                <strong>Labor:</strong> €@repairJob.LaborCost
                            </span>
                            <span class="badge bg-secondary bg-opacity-25 text-light border border-secondary px-3 py-2 rounded-pill">
                                <i class="bi bi-cpu me-1"></i> @repairJob.UsedParts.Count Parts Used
                            </span>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

<style>
    .custom-card-hover:hover {
        transform: translateY(-5px);
        box-shadow: 0 .5rem 1rem rgba(0,0,0,.3)!important;
        border-color: var(--bs-primary) !important;
    }
    .empty-state {
        background: linear-gradient(145deg, #1e1e24, #121215);
    }
</style>
