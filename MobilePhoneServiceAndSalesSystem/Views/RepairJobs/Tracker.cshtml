@model MobilePhoneServiceAndSalesSystem.Models.RepairJob

@{
    ViewData["Title"] = "Track Repair";
    var job = ViewBag.RepairJob as MobilePhoneServiceAndSalesSystem.Models.RepairJob;
    var errorMessage = ViewBag.ErrorMessage as string;
    var searchId = Context.Request.Query["searchId"].ToString();
}

<div class="container page-container">
    <div class="row justify-content-center">
        <div class="col-lg-8" style="max-width: 800px;">
            <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom border-secondary border-opacity-25">
                <h1 class="page-title mb-0">Repair Tracker</h1>
                <span class="text-muted d-none d-sm-inline">Check your device status</span>
            </div>

            <div class="retail-card mb-4 overflow-hidden border">
                <div class="card-body p-4 p-md-5 bg-gradient-brand">
                    <form method="get" action="/RepairJobs/Tracker" class="m-0">
                        <label for="searchId" class="form-label text-white fw-medium mb-3 fs-5">Enter your Repair Job ID</label>
                        <div class="d-flex gap-3 flex-column flex-sm-row">
                            <div class="flex-grow-1 position-relative">
                                <span class="position-absolute top-50 start-0 translate-middle-y ms-3 text-muted">#</span>
                                <input type="number" name="searchId" id="searchId" 
                                    class="form-control form-control-lg bg-dark text-white border-0 ps-5 shadow-inner rounded-3" 
                                    style="height: 58px;"
                                    placeholder="e.g. 1042" 
                                    value="@searchId" required />
                            </div>
                            <button type="submit" class="btn btn-primary btn-lg px-5 fw-bold rounded-3 shadow-sm d-flex align-items-center justify-content-center shadow-hover" style="height: 58px;">
                                Track Device
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert retail-card bg-dark border-start border-danger border-4 text-white p-4 mb-4 shadow d-flex align-items-center gap-3 animate-fade-in" role="alert">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" class="bi bi-exclamation-octagon text-danger flex-shrink-0" viewBox="0 0 16 16">
                      <path d="M4.54.146A.5.5 0 0 1 4.893 0h6.214a.5.5 0 0 1 .353.146l4.394 4.394a.5.5 0 0 1 .146.353v6.214a.5.5 0 0 1-.146.353l-4.394 4.394a.5.5 0 0 1-.353.146H4.893a.5.5 0 0 1-.353-.146L.146 11.46A.5.5 0 0 1 0 11.107V4.893a.5.5 0 0 1 .146-.353L4.54.146zM5.1 1 1 5.1v5.8L5.1 15h5.8l4.1-4.1V5.1L10.9 1H5.1z"/>
                      <path d="M7.002 11a1 1 0 1 1 2 0 1 1 0 0 1-2 0zM7.1 4.995a.905.905 0 1 1 1.8 0l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 4.995z"/>
                    </svg>
                    <div>
                        <h5 class="fw-bold mb-1">Not Found</h5>
                        <p class="mb-0 text-muted">@errorMessage</p>
                    </div>
                </div>
            }

            @if (job != null)
            {
                var progress = 0;
                var statusStr = job.Status.ToString();
                var statusColor = "primary";
                
                switch (statusStr)
                {
                    case "Pending": progress = 0; break;
                    case "InProgress": progress = 50; statusColor = "warning"; break;
                    case "Completed": progress = 100; statusColor = "success"; break;
                    case "Delivered": progress = 100; statusColor = "success"; break;
                    case "Cancelled": progress = 100; statusColor = "danger"; break;
                }

                <div class="retail-card p-0 overflow-hidden mb-5 animate-fade-in shadow-lg border-0">
                    <div class="p-4 p-md-5 pb-4 border-bottom border-dark position-relative" style="background: linear-gradient(145deg, var(--color-surface) 0%, #161a20 100%);">
                        <div class="position-absolute top-0 end-0 p-4 opacity-10">
                            <svg xmlns="http://www.w3.org/2000/svg" width="120" height="120" fill="currentColor" class="bi bi-tools" viewBox="0 0 16 16">
                              <path d="M1 0 0 1l2.2 3.081a1 1 0 0 0 .815.419h.07a1 1 0 0 1 .708.293l2.675 2.675-2.617 2.654A3.003 3.003 0 0 0 0 13a3 3 0 1 0 5.878-.851l2.654-2.617.968.968-.305.914a1 1 0 0 0 .242 1.023l3.27 3.27a.997.997 0 0 0 1.414 0l1.586-1.586a.997.997 0 0 0 0-1.414l-3.27-3.27a1 1 0 0 0-1.023-.242L10.5 9.5l-.96-.96 2.68-2.643A3.005 3.005 0 0 0 16 3c0-.269-.035-.53-.102-.777l-2.14 2.141L12 4l-.364-1.757L13.777.102a3 3 0 0 0-3.675 3.68L7.462 6.46 4.793 3.793a1 1 0 0 1-.293-.707v-.071a1 1 0 0 0-.419-.814L1 0Zm9.646 10.646a.5.5 0 0 1 .708 0l2.914 2.915a.5.5 0 0 1-.707.707l-2.915-2.914a.5.5 0 0 1 0-.708ZM3 11l.471.242.529.026.287.445.445.287.026.529L5 13l-.242.471-.026.529-.445.287-.287.445-.529.026L3 15l-.471-.242L2 14.732l-.287-.445L1.268 14l-.026-.529L1 13l.242-.471.026-.529.445-.287.287-.445.529-.026L3 11Z"/>
                            </svg>
                        </div>

                        <div class="d-flex justify-content-between align-items-start mb-4 position-relative z-1">
                            <div>
                                <span class="badge bg-dark border border-secondary text-light fs-6 rounded-pill px-3 py-2 fw-medium mb-3">Job ID #@job.Id</span>
                                <h3 class="text-white fw-bold mb-1">
                                    @(job.Phone?.Brand) @(job.Phone?.Model)
                                </h3>
                                <div class="text-muted fs-6">Device Information</div>
                            </div>
                        </div>
                        <p class="text-light opacity-75 fs-5 mb-0 position-relative z-1 max-w-75">"@job.Description"</p>
                    </div>
                    
                    <div class="p-4 p-md-5 bg-dark">
                        <h5 class="text-uppercase tracking-wider text-muted fs-6 fw-bold mb-5 pb-2">Tracking Timeline</h5>
                        
                        <div class="position-relative mb-5 mx-0 mx-sm-4 pb-4">
                            <div class="progress overflow-visible" style="height: 6px; background-color: var(--color-surface-hover);">
                                <div class="progress-bar bg-@statusColor rounded-pill position-relative" role="progressbar" style="width: @(progress)%; transition: width 1s ease-in-out;" aria-valuenow="@progress" aria-valuemin="0" aria-valuemax="100">
                                    <!-- Playful pulse effect on active tip -->
                                    <div class="position-absolute top-50 start-100 translate-middle rounded-circle bg-@statusColor" style="width: 14px; height: 14px; box-shadow: 0 0 0 4px rgba(var(--bs-@(statusColor)-rgb), 0.25);"></div>
                                </div>
                            </div>
                            
                            <!-- Timeline Dots -->
                            <div class="position-absolute top-50 start-0 translate-middle-y w-100 d-flex justify-content-between px-1" style="pointer-events: none;">
                                @{ void TimelineDot(int threshold, int current, string label, string icon, string align) {
                                    bool isPassed = current >= threshold;
                                    
                                    // Make dot active if its threshold exactly matches the current progress (0=Pending, 50=InProgress, 100=Completed/Cancelled).
                                    bool isActive = (threshold == 0 && current == 0) || 
                                                    (threshold == 50 && current == 50) || 
                                                    (threshold == 100 && current == 100);
                                                    
                                    // Change label/icon for the final dot if the job is cancelled.
                                    if (threshold == 100 && statusStr == "Cancelled") {
                                        label = "Cancelled";
                                        icon = "<svg width='20' height='20' fill='currentColor' viewBox='0 0 16 16'><path d='M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14m0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16'/><path d='M4.646 4.646a.5.5 0 0 1 .708 0L8 7.293l2.646-2.647a.5.5 0 0 1 .708.708L8.707 8l2.647 2.646a.5.5 0 0 1-.708.708L8 8.707l-2.646 2.647a.5.5 0 0 1-.708-.708L7.293 8 4.646 5.354a.5.5 0 0 1 0-.708z'/></svg>";
                                    }

                                    string dotColor = "secondary";
                                    if (isActive) {
                                        if (threshold == 50) dotColor = "warning";
                                        else if (threshold == 100 && statusStr == "Cancelled") dotColor = "danger";
                                        else if (threshold == 100) dotColor = "success";
                                        else dotColor = "primary";
                                    } else if (isPassed) {
                                        // Passed (but not currently active) dots should glow with status color if cancelled, else primary.
                                        dotColor = statusStr == "Cancelled" ? "danger" : "primary"; 
                                    }
                                    
                                    <div class="text-center position-relative d-inline-block" style="width: 40px; margin-left: @(align == "start" ? "0" : "auto"); margin-right: @(align == "end" ? "0" : "auto"); transform: @(align == "start" ? "translateX(-25%)" : align == "end" ? "translateX(25%)" : "translateX(0)");">
                                        <div class="rounded-circle d-flex align-items-center justify-content-center mx-auto shadow-sm bg-@dotColor @(isPassed ? "text-white" : "text-muted")" 
                                             style="width: 40px; height: 40px; border: 4px solid var(--color-surface); pointer-events: auto; z-index: 2; position: relative; transition: all 0.3s ease;">
                                            @Html.Raw(icon)
                                        </div>
                                        <div class="position-absolute start-50 translate-middle-x mt-3 w-100" style="min-width: 100px;">
                                            <span class="d-block text-@(isActive ? "white" : "muted") fw-bold small text-uppercase tracking-wider" style="white-space: nowrap;">@label</span>
                                        </div>
                                    </div>
                                } }

                                @{ TimelineDot(0, progress, "Intake", "<svg width='18' height='18' fill='currentColor' viewBox='0 0 16 16'><path d='M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14m0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16'/><path d='M10.97 4.97a.235.235 0 0 0-.02.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-1.071-1.05z'/></svg>", "start"); }
                                @{ TimelineDot(50, progress, "In Service", "<svg width='18' height='18' fill='currentColor' viewBox='0 0 16 16'><path d='M.102 2.223A3.004 3.004 0 0 0 3.78 5.897l6.341 6.252A3.003 3.003 0 0 0 13 16a3 3 0 1 0-.851-5.878L5.897 3.781A3.004 3.004 0 0 0 2.223.1l2.141 2.142L4 4l-1.757.364L.102 2.223zm13.37 9.019.528.026.287.445.445.287.026.529L15 13l-.242.471-.026.529-.445.287-.287.445-.529.026L13 15l-.471-.242L12 14.732l-.287-.445L11.268 14l-.026-.529L11 13l.242-.471.026-.529.445-.287.287-.445.529-.026L13 11l.471.242z'/></svg>", "center"); }
                                @{ TimelineDot(100, progress, "Ready", "<svg width='20' height='20' fill='currentColor' viewBox='0 0 16 16'><path d='M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14m0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16'/><path d='M10.97 4.97a.235.235 0 0 0-.02.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-1.071-1.05z'/></svg>", "end"); }
                            </div>
                        </div>

                        <div class="row g-4 mt-5 pt-4 border-top border-secondary border-opacity-25">
                            <div class="col-sm-6 col-md-3">
                                <label class="text-muted text-uppercase small fw-bold mb-2 d-block tracking-wider">Status</label>
                                <span class="badge bg-@statusColor bg-opacity-10 text-@statusColor border border-@statusColor border-opacity-25 fs-6 px-3 py-2 rounded-3 fw-semibold">@job.Status.ToString().Replace("_", " ")</span>
                            </div>
                            <div class="col-sm-6 col-md-3">
                                <label class="text-muted text-uppercase small fw-bold mb-2 d-block tracking-wider">Intake Date</label>
                                <div class="text-light fw-medium d-flex align-items-center gap-2">
                                    <svg width="16" height="16" fill="currentColor" class="bi bi-calendar3 text-secondary" viewBox="0 0 16 16">
                                      <path d="M14 0H2a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V2a2 2 0 0 0-2-2zM1 3.857C1 3.384 1.448 3 2 3h12c.552 0 1 .384 1 .857v10.286c0 .473-.448.857-1 .857H2c-.552 0-1-.384-1-.857V3.857z"/>
                                      <path d="M6.5 7a1 1 0 1 0 0-2 1 1 0 0 0 0 2zm3 0a1 1 0 1 0 0-2 1 1 0 0 0 0 2zm3 0a1 1 0 1 0 0-2 1 1 0 0 0 0 2zm-9 3a1 1 0 1 0 0-2 1 1 0 0 0 0 2zm3 0a1 1 0 1 0 0-2 1 1 0 0 0 0 2zm3 0a1 1 0 1 0 0-2 1 1 0 0 0 0 2zm3 0a1 1 0 1 0 0-2 1 1 0 0 0 0 2zm-9 3a1 1 0 1 0 0-2 1 1 0 0 0 0 2zm3 0a1 1 0 1 0 0-2 1 1 0 0 0 0 2zm3 0a1 1 0 1 0 0-2 1 1 0 0 0 0 2z"/>
                                    </svg>
                                    @job.ReceivedDate.ToString("MMM dd, yyyy")
                                </div>
                            </div>
                            <div class="col-sm-6 col-md-3">
                                <label class="text-muted text-uppercase small fw-bold mb-2 d-block tracking-wider">Handling Tech</label>
                                <div class="d-flex align-items-center gap-2">
                                    <div class="bg-secondary bg-opacity-25 rounded-circle d-flex align-items-center justify-content-center text-light fw-bold shadow-sm" style="width: 28px; height: 28px; font-size: 12px;">
                                        @(job.Technician?.FirstName?.FirstOrDefault() ?? '?')
                                    </div>
                                    <span class="text-light fw-medium">@(job.Technician != null ? $"{job.Technician.FirstName} {job.Technician.LastName}" : "Pending")</span>
                                </div>
                            </div>
                            <div class="col-sm-6 col-md-3">
                                <label class="text-muted text-uppercase small fw-bold mb-2 d-block tracking-wider">Labor Est.</label>
                                <span class="fs-5 fw-bold text-success d-flex align-items-center gap-1">
                                    @job.LaborCost.ToString("C")
                                </span>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<style>
    .tracking-wider { letter-spacing: 0.05em; }
    .shadow-inner { box-shadow: inset 0 2px 4px rgba(0,0,0,0.5); }
    .shadow-hover { transition: box-shadow 0.2s; }
    .shadow-hover:hover { box-shadow: 0 8px 16px rgba(var(--color-primary-rgb), 0.3) !important; }
    .max-w-75 { max-width: 85%; }
    .animate-fade-in { animation: fadeIn 0.4s ease-out forwards; }
    
    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>