@model IEnumerable<MobilePhoneServiceAndSalesSystem.Models.SparePart>

@{
    ViewData["Title"] = "Spare Parts";
}

@if (!Model.Any())
{
    <div class="empty-state text-center py-5 rounded-4 shadow-sm border border-secondary bg-dark text-muted">
        <div class="display-4 mb-3">
            <i class="bi bi-cpu text-secondary"></i>
        </div>
        <h3 class="fw-light">No spare parts</h3>
        <p class="mb-4">Inventory does not currently contain any active spare parts for repairs.</p>
        <a asp-action="Create" class="btn btn-outline-primary rounded-pill px-4">Register a spare part</a>
    </div>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom border-secondary">
        <div>
            <h2 class="h3 mb-0 text-white"><i class="bi bi-motherboard me-2 text-primary"></i>Spare Parts Inventory</h2>
            <p class="text-muted small mb-0 mt-1">Manage components available for device repairs</p>
        </div>
        <a asp-action="Create" class="btn btn-primary rounded-pill px-4 shadow-sm">
            <i class="bi bi-plus-lg me-2"></i>Add Spare Part
        </a>
    </div>

    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-4 g-4">
        @foreach (var sparePart in Model)
        {
            <div class="col">
                <div class="card bg-dark text-light border-secondary h-100 shadow-sm custom-card-hover" onclick="window.location='@Url.Action("Details", "SpareParts", new { id = sparePart.Id })'" style="cursor: pointer; transition: transform 0.2s, box-shadow 0.2s;">
                    <div class="card-body d-flex flex-column">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <span class="badge bg-dark border border-secondary text-secondary px-3 py-2 rounded-pill">Part #@sparePart.Id</span>
                            @if (sparePart.StockQuantity > 0)
                            {
                                <span class="badge bg-success bg-opacity-25 text-success rounded-pill border border-success px-3 py-2"><i class="bi bi-check-circle me-1"></i> @sparePart.StockQuantity In Stock</span>
                            }
                            else
                            {
                                <span class="badge bg-danger bg-opacity-25 text-danger rounded-pill border border-danger px-3 py-2"><i class="bi bi-exclamation-triangle me-1"></i> Out of Stock</span>
                            }
                        </div>
                        
                        <h5 class="card-title fw-bold text-white mb-2 pb-2 border-bottom border-secondary border-opacity-50">
                            @sparePart.Name
                        </h5>
                        <p class="card-text text-muted mb-4 small flex-grow-1">
                            <i class="bi bi-building me-1 text-secondary"></i> <strong>Manufacturer:</strong> <span class="text-light">@sparePart.Manufacturer</span>
                        </p>

                        <div class="d-flex justify-content-between align-items-center mt-auto border-top border-secondary pt-3">
                            <div class="d-flex align-items-center">
                                <span class="fw-bold fs-5 text-primary">€@sparePart.Price</span>
                            </div>
                            <div class="text-end">
                                <span class="badge bg-info bg-opacity-25 text-info border border-info px-3 py-2 rounded-pill">
                                    <i class="bi bi-wrench"></i> @sparePart.RepairJobs.Count Related Jobs
                                </span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

<style>
    .custom-card-hover:hover {
        transform: translateY(-5px);
        box-shadow: 0 .5rem 1rem rgba(0,0,0,.3)!important;
        border-color: var(--bs-primary) !important;
    }
    .empty-state {
        background: linear-gradient(145deg, #1e1e24, #121215);
    }
</style>
