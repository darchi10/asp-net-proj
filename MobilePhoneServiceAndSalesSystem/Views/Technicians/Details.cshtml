@model MobilePhoneServiceAndSalesSystem.Models.Technician

@{
    ViewData["Title"] = "Technician Profile";
}

<div class="container mt-4 mb-5">
    <div class="row g-4">
        <!-- Identity Card -->
        <div class="col-lg-4">
            <div class="card h-100 shadow-sm border-0 bg-dark text-light rounded-4 overflow-hidden position-relative">
                <div class="bg-black" style="height: 120px;"></div>
                <div class="card-body text-center px-4 pb-5 position-relative">
                    <div class="avatar-circle bg-primary text-white mx-auto d-flex align-items-center justify-content-center border border-4 border-dark shadow" style="width: 100px; height: 100px; border-radius: 50%; font-size: 2.5rem; margin-top: -50px; margin-bottom: 20px;">
                        @(Model.FirstName.FirstOrDefault())@(Model.LastName.FirstOrDefault())
                    </div>
                    <h3 class="mb-1 fw-bold">@Model.FirstName @Model.LastName</h3>
                    <p class="text-primary fw-bold text-uppercase mb-4" style="letter-spacing: 1px; font-size: 0.85rem;">@Model.Specialization</p>
                    
                    <div class="bg-secondary bg-opacity-10 rounded-3 p-3 text-start mt-4 border border-secondary">
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-secondary">Employee ID</span>
                            <span class="fw-bold">#@Model.Id</span>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-secondary">Hire Date</span>
                            <span class="fw-bold">@Model.HireDate.ToString("MMM yyyy")</span>
                        </div>
                        <div class="d-flex justify-content-between">
                            <span class="text-secondary">Base Rate</span>
                            <span class="fw-bold text-success">@Model.Salary EUR</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Operations & Stats -->
        <div class="col-lg-8">
            <div class="card shadow-sm border-0 bg-dark text-light rounded-4 mb-4">
                <div class="card-body d-flex p-4">
                     <div class="flex-grow-1 text-center border-end border-secondary">
                        <span class="text-secondary text-uppercase fw-bold d-block mb-2" style="font-size: 0.8rem; letter-spacing: 1px;">Total Jobs</span>
                        <h2 class="mb-0 fw-bold">@Model.RepairJobs.Count</h2>
                     </div>
                     <div class="flex-grow-1 text-center border-end border-secondary">
                        <span class="text-secondary text-uppercase fw-bold d-block mb-2" style="font-size: 0.8rem; letter-spacing: 1px;">Completed</span>
                        <h2 class="mb-0 fw-bold text-success">@Model.RepairJobs.Count(j => j.Status.ToString() == "Completed")</h2>
                     </div>
                     <div class="flex-grow-1 text-center">
                        <span class="text-secondary text-uppercase fw-bold d-block mb-2" style="font-size: 0.8rem; letter-spacing: 1px;">Active</span>
                        <h2 class="mb-0 fw-bold text-warning">@Model.RepairJobs.Count(j => j.Status.ToString() == "InProgress")</h2>
                     </div>
                </div>
            </div>

            <!-- Job Board -->
            <div class="card shadow-sm border-0 bg-dark text-light rounded-4 h-100">
                <div class="card-header border-bottom border-secondary bg-transparent p-4 d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 fw-bold"><i class="bi bi-clipboard-data me-2 text-primary"></i>Service Log</h5>
                </div>
                <div class="card-body p-0">
                    @if (Model.RepairJobs.Count > 0)
                    {
                        <div class="table-responsive">
                            <table class="table table-dark table-hover table-borderless align-middle mb-0">
                                <thead class="border-bottom border-secondary">
                                    <tr>
                                        <th class="py-3 ps-4 text-secondary text-uppercase" style="font-size: 0.8rem;">Ref</th>
                                        <th class="py-3 text-secondary text-uppercase" style="font-size: 0.8rem;">Task</th>
                                        <th class="py-3 text-secondary text-uppercase" style="font-size: 0.8rem;">Date</th>
                                        <th class="py-3 pe-4 text-end text-secondary text-uppercase" style="font-size: 0.8rem;">Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var job in Model.RepairJobs.OrderByDescending(j => j.ReceivedDate))
                                    {
                                        <tr class="border-bottom border-secondary" style="border-bottom-style: dashed !important;">
                                            <td class="ps-4 fw-bold">#@job.Id</td>
                                            <td class="text-truncate" style="max-width: 200px;" title="@job.Description">@job.Description</td>
                                            <td class="small text-secondary">@job.ReceivedDate.ToString("MM/dd/yy")</td>
                                            <td class="pe-4 text-end">
                                                @{
                                                    var stBadge = job.Status.ToString() == "Completed" ? "bg-success" :
                                                                  job.Status.ToString() == "InProgress" ? "bg-warning text-dark" : "bg-secondary";
                                                }
                                                <span class="badge @stBadge rounded-pill">@job.Status</span>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="p-5 text-center text-secondary">
                            <i class="bi bi-journal-x fs-1 d-block mb-3"></i>
                            <p class="mb-0">No assigned tasks logged for this technician.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
    
    <div class="mt-4">
        <a asp-controller="Technicians" asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">
            <i class="bi bi-arrow-left me-2"></i>Staff Directory
        </a>
    </div>
</div>
