@model IEnumerable<MobilePhoneServiceAndSalesSystem.Models.Technician>

@{
    ViewData["Title"] = "Technicians";
}

@if (!Model.Any())
{
    <div class="empty-state text-center py-5 rounded-4 shadow-sm border border-secondary bg-dark text-muted">
        <div class="display-4 mb-3">
            <i class="bi bi-person-badge text-secondary"></i>
        </div>
        <h3 class="fw-light">No technicians available</h3>
        <p class="mb-4">You have not hired or added any technicians to the system yet.</p>
        <a asp-action="Create" class="btn btn-outline-primary rounded-pill px-4">Add a new technician</a>
    </div>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom border-secondary">
        <div>
            <h2 class="h3 mb-0 text-white"><i class="bi bi-person-workspace me-2 text-primary"></i>Technician Roster</h2>
            <p class="text-muted small mb-0 mt-1">Manage personnel for device repairs and servicing</p>
        </div>
        <a asp-action="Create" class="btn btn-primary rounded-pill px-4 shadow-sm">
            <i class="bi bi-person-plus me-2"></i>Hire Technician
        </a>
    </div>

    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        @foreach (var technician in Model)
        {
            <div class="col">
                <div class="card bg-dark text-light border-secondary h-100 shadow-sm custom-card-hover" onclick="window.location='@Url.Action("Details", "Technicians", new { id = technician.Id })'" style="cursor: pointer; transition: transform 0.2s, box-shadow 0.2s;">
                    <div class="card-body d-flex flex-column">
                        <div class="d-flex align-items-center mb-3">
                            <i class="bi bi-person-badge-fill display-6 text-primary me-3"></i>
                            <div>
                                <h5 class="card-title fw-bold text-white mb-0">
                                    @technician.FirstName @technician.LastName
                                </h5>
                                <span class="badge bg-dark border border-secondary text-secondary mt-1">Tech ID: #@technician.Id</span>
                            </div>
                        </div>

                        <div class="card-text text-muted mb-4 small d-flex flex-column gap-2 flex-grow-1">
                            <span class="d-flex align-items-center p-2 bg-dark rounded border border-secondary border-opacity-50">
                                <i class="bi bi-stars me-2 text-warning"></i> 
                                <strong>Specialization:</strong> <span class="ms-auto text-light">@technician.Specialization</span>
                            </span>
                            <span class="d-flex align-items-center p-2 bg-dark rounded border border-secondary border-opacity-50">
                                <i class="bi bi-calendar-event me-2 text-secondary"></i> 
                                <strong>Hired:</strong> <span class="ms-auto text-light">@technician.HireDate.ToShortDateString()</span>
                            </span>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mt-auto border-top border-secondary pt-3">
                            <div class="d-flex align-items-center">
                                @if (technician.RepairJobs.Count > 0)
                                {
                                    <span class="badge bg-info bg-opacity-25 text-info border border-info px-3 py-2 rounded-pill"><i class="bi bi-wrench me-1"></i> @technician.RepairJobs.Count Assigned</span>
                                }
                                else
                                {
                                    <span class="badge bg-success bg-opacity-25 text-success border border-success px-3 py-2 rounded-pill"><i class="bi bi-check-circle me-1"></i> Available</span>
                                }
                            </div>
                            <div class="text-end">
                                <span class="badge bg-dark border border-secondary text-success px-3 py-2 rounded-pill fw-bold">
                                    €@technician.Salary / mo
                                </span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

<style>
    .custom-card-hover:hover {
        transform: translateY(-5px);
        box-shadow: 0 .5rem 1rem rgba(0,0,0,.3)!important;
        border-color: var(--bs-primary) !important;
    }
    .empty-state {
        background: linear-gradient(145deg, #1e1e24, #121215);
    }
</style>
